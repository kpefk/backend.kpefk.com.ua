generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Метод двофакторної автентифікації
enum TwoFactorMethod {
  NONE  // 2FA вимкнена
  EMAIL // Код на email
  TOTP  // Google Authenticator / Authy (TOTP RFC 6238)
}

/// Model for user authorization in the My KPEFK system
model User {
  id String @id @default(uuid())

  email    String   @unique
  password String
  role     UserRole @default(STUDENT)

  isTwoFactorEnabled Boolean          @default(false)  @map("is_two_factor_enabled")
  twoFactorMethod    TwoFactorMethod  @default(NONE)   @map("two_factor_method")
  totpSecret         String?                           @map("totp_secret")       // AES-256 encrypted base32 secret
  totpVerifiedAt     DateTime?                         @map("totp_verified_at")  // null until first TOTP confirmed

  isFirstLogin Boolean @default(true) @map("is_first_login")
  isActive     Boolean @default(true) @map("is_active")

  tokens                  Token[]
  student                 Student?
  teacher                 Teacher?
  assignedSubjectAssignments TeacherLoadSubjectAssignment[] @relation("SubjectAssignedBy")
  signedSubjectAssignments   TeacherLoadSubjectAssignment[] @relation("SubjectSignedByDirector")
  electiveSelectionsConfirmed StudentElectiveSelection[]    @relation("ElectiveSelectionConfirmedBy")
  parentInfoUpdates       ParentInfo[]
  auditLogs               AuditLog[]
  recordedLessonSessions  LessonSession[]               @relation("LessonSessionRecordedBy")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@map("users")
}

/// Model for tokens
model Token {
  id String @id @default(uuid())

  token     String    @unique
  type      TokenType
  expiresIn DateTime  @map("expires_in")

  // Нова email-адреса для підтвердження зміни (лише для type = EMAIL_CHANGE)
  newEmail String? @map("new_email")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("tokens")
}

/// List of user roles in the My KPEFK system
enum UserRole {
  STUDENT             // Студент
  TEACHER             // Викладач
  SCHEDULE_DISPATCHER // Диспетчер розкладу
  HEAD_OF_DEPARTMENT  // Завідувач відділення
  DEPUTY_DIRECTOR     // Заступник директора
  DIRECTOR            // Директор
  ADMINISTRATOR       // Адміністратор
}

/// Model for token types
enum TokenType {
  TWO_FACTOR     // Two-factor authentication
  PASSWORD_RESET // Password reset
  EMAIL_CHANGE   // Email change confirmation
}

/// Стан інкрементальної синхронізації з ЄДЕБО.
/// Зберігає дату останнього успішного запуску кожного типу синхронізації.
/// Ключі: students_last_sync_at, staff_last_sync_at
model SyncState {
  key       String   @id
  value     String   // ISO 8601 рядок дати
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@map("sync_state")
}

/// Причина зміни групи студента
enum GroupChangeReason {
  EDEBO_SYNC       // Зміна виявлена при синхронізації, тип невизначений
  COURSE_PROMOTION // Масове переведення на наступний курс
  TRANSFER         // Переведення одного студента в іншу групу
  MANUAL           // Ручне коригування адміністратором
}

/// Model for detailed student information
model Student {
  id String @id @default(uuid())

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String? @unique @map("user_id")

  universityId Int @map("university_id") // Код закладу в ЄДЕБО
  personId     Int @map("person_id")     // Код картки фіз. особи в ЄДЕБО
  educationId  Int @map("education_id")  // Код картки навчання в ЄДЕБО

  // Код особи (рядковий)
  personCodeU String @map("person_code_u")

  // Актуальний запис історії навчання
  educationHistoryActualId Int      @map("education_history_actual_id")
  dateBegin                DateTime? @map("date_begin")
  dateEnd                  DateTime? @map("date_end")
  historyTypeId            Int      @map("history_type_id")

  // Персональні дані
  personFIO     String   @map("person_fio")      // ПІБ
  personNameEn  String?  @map("person_name_en")  // ПІБ транслітерацією (з ЄДЕБО)
  birthday      DateTime?                         // Дата народження
  personSexName String?  @map("person_sex_name")  // Стать

  // Навчання
  licenseYear          Int?      @map("license_year")           // Рік ліцензійних обсягів
  educationDateBegin   DateTime? @map("education_date_begin")   // Початок навчання
  educationDateEnd     DateTime? @map("education_date_end")     // Закінчення навчання
  facultyName          String?   @map("faculty_name")           // Структурний підрозділ
  qualificationGroupId Int?      @map("qualification_group_id") // Освітній ступінь (Id)
  qualificationGroupName String? @map("qualification_group_name") // Освітній ступінь (назва)
  educationFormId      Int?      @map("education_form_id")      // Форма навчання (Id)
  educationFormName    String?   @map("education_form_name")    // Форма навчання (назва)
  personEducationPaymentTypeName String? @map("person_education_payment_type_name") // Джерело фінансування (державна/контракт)
  isDualForm           Boolean?  @map("is_dual_form")           // Дуальна форма навчання
  isSecondHigher       Boolean?  @map("is_second_higher")       // Здобуття за іншою спеціальністю
  isShortTerm          Boolean?  @map("is_short_term")          // Скорочений термін
  fullSpecialityName   String?   @map("full_speciality_name")   // Спеціальність
  universityStudyProgramId Int?  @map("university_study_program_id") // Освітня програма (Id)
  studyProgramName     String?   @map("study_program_name")    // Освітня програма (назва)
  professionInfo       String?   @map("profession_info")        // Кваліфікація
  courseId             Int?      @map("course_id")              // Курс (Id)
  courseName           String?   @map("course_name")            // Курс (назва)
  groupName            String?   @map("group_name")             // Назва групи (з ЄДЕБО, для порівняння)

  // FK на Group — встановлюється після syncFromStudents
  groupId String? @map("group_id")
  group   Group?  @relation(fields: [groupId], references: [id], onDelete: SetNull)

  // Відрахування / академвідпустка
  expelEducationTypeName String? @map("expel_education_type_name") // Причина відрахування
  academicLeaveTypeName  String? @map("academic_leave_type_name")  // Підстава академвідпустки

  // Іноземці
  foreignTypeId   Int?    @map("foreign_type_id")   // Категорія іноземців (Id)
  foreignTypeName String? @map("foreign_type_name") // Категорія іноземців (назва)

  // Переведення на бюджет
  budgetTransferCategoryId   Int?    @map("budget_transfer_category_id")   // Категорія (Id)
  budgetTransferCategoryName String? @map("budget_transfer_category_name") // Категорія (назва)

  // Аспірантура
  isForPhdRenewal Boolean? @map("is_for_phd_renewal")

  // Документи для реєстрації та верифікації
  rnokpp                     String? @map("rnokpp")                       // РНОКПП/ІПН
  passportDocumentSeries     String? @map("passport_document_series")     // Серія паспорта/студентського квитка
  passportDocumentNumbers    String? @map("passport_document_numbers")    // Номер паспорта/студентського квитка
  studentTicketSeries        String? @map("student_ticket_series")        // Серія студентського квитка
  studentTicketNumbers       String? @map("student_ticket_numbers")       // Номер студентського квитка
  passportSeries             String? @map("passport_series")              // Серія паспорта
  passportNumbers            String? @map("passport_numbers")             // Номер паспорта

  // Корпоративна пошта Google Workspace
  corporateEmail String? @unique @map("corporate_email") // Згенерована корпоративна пошта

  // Службові поля
  createdAt  DateTime  @default(now()) @map("created_at")
  modifyDate DateTime? @map("modify_date") // Дата останнього редагування в ЄДЕБО

  groupHistory StudentGroupHistory[]

  // Curriculum domain (back-relations — no new columns)
  individualPlan        StudentIndividualPlan?
  electiveSelections    StudentElectiveSelection[]
  electiveRegistrations ElectiveRegistration[]

  // Attendance domain (back-relations)
  subgroups         StudentSubgroup[]
  attendanceRecords AttendanceRecord[]

  parentInfo ParentInfo?

  @@map("students")
}

/// Academic group — derived from students' groupName field via ЄДЕБО sync.
/// Created automatically during sync; cannot be created manually.
/// Only curator assignment is stored here; all other metadata comes from students.
model Group {
  id   String @id @default(uuid())
  name String @unique // groupName from students (ЄДЕБО)

  curatorId String?  @unique @map("curator_id")
  curator   Teacher? @relation(fields: [curatorId], references: [id], onDelete: SetNull)

  students    Student[]
  historyFrom StudentGroupHistory[] @relation("FromGroup")
  historyTo   StudentGroupHistory[] @relation("ToGroup")

  // Curriculum domain (back-relations — no new columns)
  curriculumAssignments        GroupCurriculumAssignment[]
  workingCurriculumAssignments GroupWorkingCurriculumAssignment[]
  subjectAssignments           TeacherLoadSubjectAssignment[]
  schedules                    Schedule[]
  studentSubgroups             StudentSubgroup[]
  lessonSessions               LessonSession[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@map("groups")
}

/// Хронологія переміщень студента між групами
model StudentGroupHistory {
  id String @id @default(uuid())

  studentId String  @map("student_id")
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  fromGroupId String? @map("from_group_id")
  fromGroup   Group?  @relation("FromGroup", fields: [fromGroupId], references: [id], onDelete: SetNull)

  toGroupId String? @map("to_group_id")
  toGroup   Group?  @relation("ToGroup", fields: [toGroupId], references: [id], onDelete: SetNull)

  reason    GroupChangeReason @default(EDEBO_SYNC)
  changedAt DateTime          @default(now()) @map("changed_at")

  @@map("student_group_history")
}

/// Model for detailed teacher information (ЄДЕБО API: university/staff/list)
model Teacher {
  id String @id @default(uuid())

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String? @unique @map("user_id")

  personId Int @map("person_id") // Код картки фіз. особи в ЄДЕБО
  staffId  Int @unique @map("staff_id") // Код картки працівника в ЄДЕБО

  // Персональні дані
  lastName      String   @map("last_name")       // Прізвище
  firstName     String   @map("first_name")      // Власне ім'я
  middleName    String?  @map("middle_name")     // По батькові
  birthday      DateTime?                         // Дата народження
  countryName   String?  @map("country_name")    // Громадянство
  personSexName String?  @map("person_sex_name") // Стать

  // Посада та зайнятість
  isActive              Boolean @default(true) @map("is_active")        // Працює (так/ні)
  positionName          String? @map("position_name")                   // Посада
  positionPluralityName String? @map("position_plurality_name")         // Трудовий статус
  positionPlace         String? @map("position_place")                  // Місце основної роботи

  // Факультет
  universityFacultyId        Int?    @map("university_faculty_id")
  universityFacultyFullName  String? @map("university_faculty_full_name")
  universityFacultyShortName String? @map("university_faculty_short_name")

  // Кафедра
  universityFacultyChairId        Int?    @map("university_faculty_chair_id")
  universityFacultyChairFullName  String? @map("university_faculty_chair_full_name")
  universityFacultyChairShortName String? @map("university_faculty_chair_short_name")

  // Кваліфікація
  profession    String? // Професія
  rang          String? // Розряд
  dignityIdsStr String? @map("dignity_ids_str") // Педагогічні звання (Id через кому)
  dignityNames  String? @map("dignity_names")   // Педагогічні звання (назви)
  skillId       Int?    @map("skill_id")         // Кваліфікаційна категорія (Id)
  skillName     String? @map("skill_name")       // Кваліфікаційна категорія (назва)

  // Стаж
  stageTypeId   Int?      @map("stage_type_id")
  stageTypeName String?   @map("stage_type_name")
  stage         Int?
  isStageSolid  Boolean?  @map("is_stage_solid")
  startDate     DateTime? @map("start_date")

  // Дати роботи
  dateRecruit DateTime? @map("date_recruit")
  dateFire    DateTime? @map("date_fire")

  // Підвищення кваліфікації
  coursesInfo String? @map("courses_info")

  // Службові поля
  createdAt  DateTime  @default(now()) @map("created_at")
  modifyDate DateTime? @map("modify_date") // Дата останньої зміни в ЄДЕБО

  /// Ставка викладача (0.25 / 0.5 / 0.75 / 1.0 / 1.25 / 1.5).
  /// Пропорційно визначає ліміт навчального навантаження: 720 × rate год/рік.
  rate Decimal @default(1.0) @db.Decimal(3, 2)

  classrooms                 Classroom[]
  group                      Group?
  workingComponentTerms      WorkingCurriculumComponentTerm[]
  primarySubjectAssignments  TeacherLoadSubjectAssignment[]    @relation("SubjectPrimaryTeacher")
  lessonOverrideAssignments  TeacherLoadLessonAssignment[]     @relation("LessonOverrideTeacher")
  qualificationUpgrades      TeacherQualificationUpgrade[]
  scheduleEntries            ScheduleEntry[]
  substitutionReplacements   ScheduleSubstitution[]            @relation("SubstitutionTeacher")
  lessonSessions             LessonSession[]

  @@map("teachers")
}

enum QualificationUpgradeSource {
  EDEBO_PARSED /// Авто-розпарсено з Teacher.coursesInfo (ЄДЕБО)
  MANUAL       /// Введено вручну адміністратором
}

/// Підвищення кваліфікації педагогічного працівника.
/// Ст. 24 Закону №2745-VIII: кожен педагогічний працівник зобов'язаний підвищувати
/// кваліфікацію не рідше одного разу на 5 років. Обсяг — не менше 120 годин за 5 років.
model TeacherQualificationUpgrade {
  id String @id @default(uuid())

  teacherId String  @map("teacher_id")
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  /// Джерело запису: EDEBO_PARSED = авто з coursesInfo; MANUAL = введено адміністратором
  source QualificationUpgradeSource @default(MANUAL)

  /// Оригінальний фрагмент тексту (для EDEBO_PARSED — вихідний рядок запису)
  rawText String? @map("raw_text")

  /// Назва курсу / заходу підвищення кваліфікації
  courseName String @map("course_name")

  /// Назва організації, що проводила підвищення кваліфікації
  organizationName String? @map("organization_name")

  /// Дата початку
  startDate DateTime @map("start_date")

  /// Дата закінчення
  endDate DateTime @map("end_date")

  /// Обсяг у годинах (≥ 120 год за 5 років)
  hours Int

  /// Серія та номер свідоцтва / сертифіката
  certificateNumber String? @map("certificate_number")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@map("teacher_qualification_upgrades")
}

/// Model for classrooms
// ── Curriculum domain relations added below ──────────────────────────────────
// Group and Student are extended with back-relations only (no new columns).

/// Тип аудиторії — для перевірки відповідності виду заняття (ТЗ §3.7).
enum ClassroomType {
  LECTURE  // Лекційна
  PRACTICE // Для практичних/семінарів
  LAB      // Лабораторна (спецаудиторія)
  COMPUTER // Комп'ютерний клас
  SPORTS   // Спортивна зала
  OTHER    // Інше / універсальна
}

model Classroom {
  id String @id @default(uuid())

  number String @unique // Classroom number (№6, №6а, №10)
  name   String @unique // Classroom name (Scientific and natural sciences classroom, Software laboratory)
  photos Json   @default("[]") // Photos of the classroom (Up to 4 photos)

  /// Місткість (к-сть місць) — для перевірки місткості vs розмір групи (ТЗ §3.7).
  capacity Int?
  /// Тип аудиторії — для перевірки відповідності типу заняття (ТЗ §3.7).
  type     ClassroomType?

  // Passport (PDF)
  passportGoogleFileId String? @map("passport_google_file_id")
  passportUrl          String? @map("passport_url")

  // Head of the classroom
  teacherId String?  @map("teacher_id")
  teacher   Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)

  scheduleEntries          ScheduleEntry[]
  substitutionReplacements ScheduleSubstitution[] @relation("SubstitutionClassroom")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@map("classrooms")
}

// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║                        CURRICULUM DOMAIN                                    ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

// ─── Enums ────────────────────────────────────────────────────────────────────

/// Форма здобуття освіти
enum EducationForm {
  FULL_TIME // Денна
  PART_TIME // Заочна
  DUAL      // Дуальна
}

/// Підстава для вступу (рівень базової освіти)
enum AdmissionBasis {
  AFTER_9TH_GRADE  // На основі 9 класів (базова середня освіта)
  AFTER_11TH_GRADE // На основі 11 класів (повна загальна середня освіта)
}

/// Тип розділу навчального плану
enum CurriculumSectionType {
  // ── Профільна середня освіта ──────────────────────────────────────────────
  SECONDARY_EDUCATION     // Загальна середня освіта (legacy / сумарний блок ЗСО)
  BASIC_OPP               // Базові компоненти ОПП
  ELECTIVE_OPP            // Вибірково-обов'язкові компоненти ОПП
  OPTIONAL_COURSES        // Факультативні курси

  // ── Фахова підготовка ─────────────────────────────────────────────────────
  GENERAL_COMPETENCY      // Загальні компетентності
  PROFESSIONAL_COMPETENCY // Фахові компетентності
  ELECTIVE                // Вибіркова частина (ВК)
  PRACTICE                // Практична підготовка
  ATTESTATION             // Атестація здобувачів ФПО
  CFP                     // Цикл фахової підготовки (ЦФП)
}

/// Форма підсумкового контролю за семестр (на рівні терміну)
enum TermControlForm {
  EXAM          // Екзамен
  CREDIT        // Залік
  GRADED_CREDIT // Диференційований залік
}

/// Укрупнена категорія освітнього компонента (для структури плану)
enum CurriculumComponentType {
  REGULAR       // Звичайна навчальна дисципліна
  PRACTICE      // Виробнича / переддипломна практика
  ATTESTATION   // Атестація / захист / ЗНО
  ELECTIVE_GROUP // Вибіркова група (студент обирає одну з кількох дисциплін)
}

/// Тип освітнього компонента
enum ComponentType {
  DISCIPLINE                 // Навчальна дисципліна
  PRACTICE                   // Практика
  COURSE_WORK                // Курсова робота
  COURSE_PROJECT             // Курсовий проект
  DIPLOMA_PROJECT            // Дипломне проектування
  QUALIFICATION_WORK_DEFENSE // Захист кваліфікаційної роботи
  QUALIFICATION_EXAM         // Кваліфікаційний іспит
  STATE_EXAM                 // Державний іспит / ЄДКІ / НМТ / ЗНО
}

/// Форма підсумкового контролю в семестрі
enum ControlForm {
  EXAM                // Екзамен
  TEST                // Залік
  DIFFERENTIATED_TEST // Диференційований залік
  COURSE_WORK         // Курсова робота
  COURSE_PROJECT      // Курсовий проект
  NONE                // Без підсумкового контролю (розподільчий рядок)
}

/// Вид практики
enum PracticeType {
  EDUCATIONAL    // Навчальна практика
  TECHNOLOGICAL  // Технологічна / виробнича практика
  PRE_GRADUATION // Переддипломна практика
}

/// Тип тижня в графіку навчального процесу
enum CalendarWeekType {
  INSTRUCTION       // Теоретичне навчання
  EXAM_SESSION      // Екзаменаційна сесія
  PRACTICE          // Практика
  HOLIDAY           // Канікули
  NATIONAL_HOLIDAY  // Святкові дні
  STATE_ATTESTATION // Державна підсумкова атестація (ЗНО / НМТ)
  GRADUATION_WORK   // Дипломне проектування / кваліфікаційна робота
  DEFENSE           // Захист КР / кваліфікаційний іспит
}

/// Тип відхилення в індивідуальному навчальному плані
enum IndividualPlanDeviationType {
  ELECTIVE_SELECTION   // Вибір вибіркового компонента
  RETAKE               // Перездача
  EXTENDED_DEADLINE    // Продовження терміну
  TRANSFERRED_CREDIT   // Перезарахований кредит
  EXEMPTED             // Звільнення від компонента
  ACCELERATED          // Прискорене освоєння
  ADDITIONAL_COMPONENT // Додатковий компонент
}

// ─── Core: Specialty ──────────────────────────────────────────────────────────

/// Спеціальність (ліцензована одиниця, наприклад: F3 Комп'ютерні науки)
model Specialty {
  id        String  @id @default(uuid())
  code      String  @unique          // "F3", "D3", "073"
  name      String                   // "Комп'ютерні науки"
  shortName String? @map("short_name")
  isActive  Boolean @default(true) @map("is_active")

  /// Код спеціальності в ЄДЕБО (universityStudyPrograms.specialityId).
  /// Заповнюється під час синхронізації освітніх програм.
  edeboSpecialityId Int? @unique @map("edebo_speciality_id")

  programs EducationalProgram[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@map("specialties")
}

// ─── Core: Educational Program (OPP) ─────────────────────────────────────────

/// Освітньо-професійна програма (ОПП).
/// Одна ОПП може породжувати декілька навчальних планів (по формі, базі, року).
model EducationalProgram {
  id                  String    @id @default(uuid())
  specialtyId         String    @map("specialty_id")
  specialty           Specialty @relation(fields: [specialtyId], references: [id])

  name                String            // "Комп'ютерні науки"
  qualificationName   String            @map("qualification_name")   // "Фаховий молодший бакалавр з комп'ютерних наук"
  qualificationLevel  String?           @map("qualification_level")  // "Фаховий молодший бакалавр"
  edeboId             Int?    @unique   @map("edebo_id")             // universityStudyProgramId з ЄДЕБО
  approvalDate        DateTime?         @map("approval_date")
  approvalOrderNumber String?           @map("approval_order_number")
  isActive            Boolean @default(true) @map("is_active")
  notes               String?

  // ── Поля, заповнювані при синхронізації з ЄДЕБО ──────────────────────────
  studyProgramNameEn         String?   @map("study_program_name_en")
  qualificationGroupId       Int?      @map("qualification_group_id")
  qualificationGroupName     String?   @map("qualification_group_name")
  universitySpecializationId Int?      @map("university_specialization_id")
  specializationName         String?   @map("specialization_name")
  /// 1 = Акредитовано ОП, 2 = Акредитовано спеціальність, null = не акредитовано
  accreditationExistsType    Int?      @map("accreditation_exists_type")
  accreditationExistsTypeName String?  @map("accreditation_exists_type_name")
  edeboDateLastChange        DateTime? @map("edebo_date_last_change")
  /// Час останньої успішної синхронізації з ЄДЕБО
  syncedAt                   DateTime? @map("synced_at")

  curricula Curriculum[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([specialtyId])
  @@map("educational_programs")
}

// ─── Core: Curriculum ─────────────────────────────────────────────────────────

/// Навчальний план — контейнер версій.
/// Унікальний для (ОПП × форма навчання × база освіти × рік вступу).
model Curriculum {
  id                  String             @id @default(uuid())
  programId           String             @map("program_id")
  program             EducationalProgram @relation(fields: [programId], references: [id])

  educationForm       EducationForm  @map("education_form")
  admissionBasis      AdmissionBasis @map("admission_basis")
  entryYear           Int            @map("entry_year")
  studyDurationMonths Int            @map("study_duration_months")
  totalEcts           Decimal        @map("total_ects") @db.Decimal(6, 2)
  isActive            Boolean        @default(true) @map("is_active")
  notes               String?

  versions         CurriculumVersion[]
  groupAssignments GroupCurriculumAssignment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([programId, educationForm, admissionBasis, entryYear])
  @@index([programId])
  @@index([entryYear])
  @@map("curricula")
}

// ─── Core: Curriculum Version ─────────────────────────────────────────────────

/// Версія навчального плану.
/// Після публікації (isPublished = true) нормативні поля незмінні.
/// Виправлення вносяться через нову версію, а не перезапис.
model CurriculumVersion {
  id                  String     @id @default(uuid())
  curriculumId        String     @map("curriculum_id")
  curriculum          Curriculum @relation(fields: [curriculumId], references: [id])

  versionNumber       Int      @map("version_number")
  // Метадані затвердження зберігаються опційно: плани заходять у систему вже
  // офіційно затвердженими, тож введення цих полів не вимагається. Колонки
  // лишаємо для майбутніх друкованих витягів/звітності.
  approvalDate        DateTime? @map("approval_date")
  approvalOrderNumber String?   @map("approval_order_number")
  approvedBy          String?   @map("approved_by")
  isPublished         Boolean  @default(false) @map("is_published")
  publishedAt         DateTime? @map("published_at")
  deprecatedAt        DateTime? @map("deprecated_at") // null = ще актуальна
  notes               String?

  sections          CurriculumSection[]
  timeBudgetEntries TimeBudgetEntry[]
  calendarEntries   AcademicCalendarEntry[]
  workingCurricula  WorkingCurriculum[]
  groupAssignments  GroupCurriculumAssignment[]

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([curriculumId, versionNumber])
  @@index([curriculumId])
  @@map("curriculum_versions")
}

// ─── Structure: Section ───────────────────────────────────────────────────────

/// Розділ навчального плану (блок ЗСО, цикл загальної підготовки тощо)
model CurriculumSection {
  id          String            @id @default(uuid())
  versionId   String            @map("version_id")
  version     CurriculumVersion @relation(fields: [versionId], references: [id], onDelete: Restrict)

  code         String?               // "ЗСО", "ЦЗП", "ЦФП"
  name         String
  orderIndex   Int                   @map("order_index")
  sectionType  CurriculumSectionType @map("section_type")
  subtotalEcts Decimal?              @map("subtotal_ects") @db.Decimal(6, 2)

  components         CurriculumComponent[]
  electiveBlocks     ElectiveBlock[]
  displayProjections CurriculumComponentDisplayInSection[]

  @@index([versionId])
  @@map("curriculum_sections")
}

// ─── Structure: Elective Block ────────────────────────────────────────────────

/// Блок вибіркових компонентів (студент вибирає N з M варіантів у семестрі)
model ElectiveBlock {
  id            String            @id @default(uuid())
  sectionId     String            @map("section_id")
  section       CurriculumSection @relation(fields: [sectionId], references: [id], onDelete: Restrict)

  name           String // "Блок вільного вибору 4 семестр"
  semesterNumber Int    @map("semester_number")
  minSelections  Int    @default(1) @map("min_selections")
  maxSelections  Int    @default(1) @map("max_selections")
  orderIndex     Int    @map("order_index")

  options         CurriculumComponent[]
  groupSelections GroupElectiveSelection[]
  seasons         ElectiveBlockSeason[]

  @@index([sectionId])
  @@map("elective_blocks")
}

// ─── Structure: Component ─────────────────────────────────────────────────────

/// Освітній компонент навчального плану
model CurriculumComponent {
  id        String            @id @default(uuid())
  sectionId String            @map("section_id")
  section   CurriculumSection @relation(fields: [sectionId], references: [id], onDelete: Restrict)

  // Для вибіркових компонентів — посилання на блок
  electiveBlockId String?        @map("elective_block_id")
  electiveBlock   ElectiveBlock? @relation(fields: [electiveBlockId], references: [id])

  code          String?       // "ОК1", "ВК1"
  name          String
  componentType ComponentType @map("component_type")
  totalEcts     Decimal       @map("total_ects") @db.Decimal(6, 2)
  totalHours    Int           @map("total_hours")
  orderIndex    Int           @map("order_index")
  isMandatory   Boolean       @default(true) @map("is_mandatory")

  practiceType PracticeType? @map("practice_type") // лише для PRACTICE-типу

  courseWorkCount    Int @default(0) @map("course_work_count")
  courseProjectCount Int @default(0) @map("course_project_count")

  notes String?

  // ── Укрупнена категорія (новий класифікатор) ──────────────────────────────
  componentKind CurriculumComponentType @default(REGULAR) @map("component_kind")

  // ── Розподіл годин ────────────────────────────────────────────────────────
  auditoryHours       Int? @map("auditory_hours")       // Аудиторні (загалом)
  lectureHours        Int? @map("lecture_hours")        // Лекційні
  practicalHours      Int? @map("practical_hours")      // Практичні заняття
  seminarHours        Int? @map("seminar_hours")        // Семінарські
  labHours            Int? @map("lab_hours")            // Лабораторні
  selfStudyHours      Int? @map("self_study_hours")     // Самостійна робота
  otherHours          Int? @map("other_hours")          // Інші (консультації тощо)
  znoPreparationHours Int? @map("zno_preparation_hours") // Підготовка до ЗНО (тільки для ЗСО)

  // ── Вибіркова група: ієрархія альтернатив ─────────────────────────────────
  groupCode         String?             @map("group_code")          // "ВК1", "ВК4"
  parentComponentId String?             @map("parent_component_id")
  parentComponent   CurriculumComponent? @relation("ComponentAlternatives", fields: [parentComponentId], references: [id], onDelete: SetNull)
  alternatives      CurriculumComponent[] @relation("ComponentAlternatives")

  terms              CurriculumComponentTerm[]
  planItems          StudentIndividualPlanItem[]
  groupSelections    GroupElectiveSelection[]
  offerings          ElectiveOffering[]
  electiveSelections StudentElectiveSelection[]
  displayProjections CurriculumComponentDisplayInSection[]

  @@index([sectionId])
  @@index([electiveBlockId])
  @@index([parentComponentId])
  @@map("curriculum_components")
}

// ─── Structure: Component Term ────────────────────────────────────────────────

/// Розподіл компонента по семестру — ЄКТС, години, форма контролю
model CurriculumComponentTerm {
  id          String              @id @default(uuid())
  componentId String              @map("component_id")
  component   CurriculumComponent @relation(fields: [componentId], references: [id], onDelete: Restrict)

  semesterNumber   Int              @map("semester_number")
  ects             Decimal          @db.Decimal(6, 2)
  hours            Int
  hoursPerWeek     Int?             @map("hours_per_week")   // Годин на тиждень (знаменник у "34/2")
  controlForm      TermControlForm? @map("control_form")     // Форма підсумкового контролю (null = не вказано)
  hasCourseWork    Boolean          @default(false) @map("has_course_work")
  hasCourseProject Boolean          @default(false) @map("has_course_project")

  /// Кількість підгруп для практичних / лабораторних занять.
  /// 1 = не ділиться на підгрупи; 2+ = кількість підгруп.
  subgroupCount Int @default(1) @map("subgroup_count")

  /// Текстова підстава для поділу на підгрупи (напр. «Наказ №12 від...»
  /// або «Вимоги техніки безпеки»). Опційно; відображається в листку навантаження.
  subgroupJustification String? @map("subgroup_justification")

  workingTerms       WorkingCurriculumComponentTerm[]
  subjectAssignments TeacherLoadSubjectAssignment[]
  scheduleEntries    ScheduleEntry[]
  studentSubgroups   StudentSubgroup[]
  lessonSessions     LessonSession[]
  /// @deprecated back-relation для ElectiveComponent.curriculumTermId (deprecated)
  electiveComponent  ElectiveComponent?

  @@unique([componentId, semesterNumber])
  @@index([componentId])
  @@map("curriculum_component_terms")
}

// ─── Structure: Component Display Projection ──────────────────────────────────

/// Відображення освітнього компонента в додатковому розділі (інтеграційна проекція).
///
/// Канонічний компонент живе в одному основному розділі (CurriculumComponent.sectionId).
/// Цей рядок лише вказує «також показати в розділі X» для цілей відображення —
/// без дублювання сутності, годин, ЄКТС, термінів або будь-яких агрегатів.
///
/// Інваріанти, що забезпечуються сервісом:
///   • componentId та sectionId належать до ОДНІЄЇ версії навчального плану.
///   • sectionId ≠ component.sectionId (не можна проектувати в основний розділ).
///   • Проекція не може бути створена/видалена після публікації версії.
///   • Проекція не впливає на підрахунок підсумків розділу або плану в цілому.
model CurriculumComponentDisplayInSection {
  id            String  @id @default(uuid())
  componentId   String  @map("component_id")
  sectionId     String  @map("section_id")
  displayOrder  Int     @default(0) @map("display_order")
  /// Позначка-маркер для відображення поруч з назвою (наприклад «*»)
  displayMarker String? @map("display_marker")
  /// Пояснювальна нотатка (наприклад «Інтегровано з ОК3»)
  displayNote   String? @map("display_note")

  component CurriculumComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)
  section   CurriculumSection   @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([componentId, sectionId])
  @@index([sectionId, displayOrder])
  @@index([componentId])
  @@map("curriculum_component_display_in_sections")
}

// ─── Structure: Time Budget ───────────────────────────────────────────────────

/// Зведені дані бюджету часу (верифікаційна таблиця плану)
model TimeBudgetEntry {
  id        String            @id @default(uuid())
  versionId String            @map("version_id")
  version   CurriculumVersion @relation(fields: [versionId], references: [id], onDelete: Restrict)

  label      String           // "Аудиторних годин", "Самостійна робота"
  totalHours Int              @map("total_hours")
  totalEcts  Decimal?         @map("total_ects") @db.Decimal(6, 2)
  orderIndex Int              @map("order_index")

  @@index([versionId])
  @@map("time_budget_entries")
}

// ─── Structure: Academic Calendar ─────────────────────────────────────────────

/// Графік навчального процесу: тиждень → тип тижня
model AcademicCalendarEntry {
  id        String            @id @default(uuid())
  versionId String            @map("version_id")
  version   CurriculumVersion @relation(fields: [versionId], references: [id], onDelete: Restrict)

  courseNumber   Int              @map("course_number")
  semesterNumber Int              @map("semester_number")
  weekNumber     Int              @map("week_number")
  weekType       CalendarWeekType @map("week_type")

  @@unique([versionId, courseNumber, semesterNumber, weekNumber])
  @@index([versionId])
  @@map("academic_calendar_entries")
}

// ─── Operational: Group Curriculum Assignment ─────────────────────────────────

/// Нормативне прив'язування групи до версії навчального плану.
/// Зберігається повна historія — записи не видаляються, а закриваються.
model GroupCurriculumAssignment {
  id           String            @id @default(uuid())
  groupId      String            @map("group_id")
  group        Group             @relation(fields: [groupId], references: [id])
  curriculumId String            @map("curriculum_id")
  curriculum   Curriculum        @relation(fields: [curriculumId], references: [id])
  versionId    String            @map("version_id")
  version      CurriculumVersion @relation(fields: [versionId], references: [id])

  effectiveFrom  DateTime  @map("effective_from")
  effectiveUntil DateTime? @map("effective_until") // null = активне прив'язання
  isActive       Boolean   @default(true) @map("is_active")
  assignedBy     String?   @map("assigned_by")     // userId
  reason         String?                            // причина призначення

  electiveSelections   GroupElectiveSelection[]
  workingAssignments   GroupWorkingCurriculumAssignment[]
  studentPlans         StudentIndividualPlan[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([groupId, isActive])
  @@index([versionId])
  @@map("group_curriculum_assignments")
}

// ─── Operational: Working Curriculum ─────────────────────────────────────────

/// Робочий навчальний план — операційний шар для конкретного навчального року.
/// Один на (версія плану × навчальний рік).
model WorkingCurriculum {
  id           String            @id @default(uuid())
  versionId    String            @map("version_id")
  version      CurriculumVersion @relation(fields: [versionId], references: [id])

  academicYear    String  @map("academic_year")    // "2024-2025"
  semesterNumbers Int[]   @map("semester_numbers") // наприклад [3, 4]
  isApproved      Boolean @default(false) @map("is_approved")
  approvedAt      DateTime? @map("approved_at")
  notes           String?

  /// Дата засідання педагогічної ради, на якій затверджено РНП (Ст. 37 Закону №2745-VIII).
  /// null = рішення педради ще не зафіксовано.
  pedagogicalCouncilDate           DateTime? @map("pedagogical_council_date")
  /// Номер протоколу засідання педагогічної ради.
  pedagogicalCouncilProtocolNumber String?   @map("pedagogical_council_protocol_number")

  /// Дата погодження навантаження з профспілковим комітетом (Ст. 60 п.5 №2745-VIII).
  /// null = погодження ще не зафіксовано.
  tradeUnionApprovedAt     DateTime? @map("trade_union_approved_at")
  /// Номер протоколу засідання профспілкового комітету.
  tradeUnionProtocolNumber String?   @map("trade_union_protocol_number")

  componentTerms     WorkingCurriculumComponentTerm[]
  subjectAssignments TeacherLoadSubjectAssignment[]
  schedules          Schedule[]
  /// Snapshot-layer: explicit group bindings recorded at assignment time.
  /// For live/current group membership use GroupCurriculumAssignment WHERE versionId AND isActive.
  groupSnapshots GroupWorkingCurriculumAssignment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([versionId, academicYear])
  @@index([versionId])
  @@map("working_curricula")
}

// ─── Operational: Working Curriculum Component Term ───────────────────────────

/// Розбивка годин за видами роботи для конкретного робочого плану
model WorkingCurriculumComponentTerm {
  id                  String                  @id @default(uuid())
  workingCurriculumId String                  @map("working_curriculum_id")
  workingCurriculum   WorkingCurriculum        @relation(fields: [workingCurriculumId], references: [id], onDelete: Cascade)
  componentTermId     String                  @map("component_term_id")
  componentTerm       CurriculumComponentTerm @relation(fields: [componentTermId], references: [id], onDelete: Restrict)

  lectureHours      Int @default(0) @map("lecture_hours")
  practicalHours    Int @default(0) @map("practical_hours")
  labHours          Int @default(0) @map("lab_hours")
  seminarHours      Int @default(0) @map("seminar_hours")
  independentHours  Int @default(0) @map("independent_hours")
  consultationHours Int @default(0) @map("consultation_hours")

  weeklyLectureHours   Decimal? @map("weekly_lecture_hours")   @db.Decimal(4, 1)
  weeklyPracticalHours Decimal? @map("weekly_practical_hours") @db.Decimal(4, 1)

  /// Режим розподілу практичних/лабораторних: потік чи окремо на кожну групу.
  practiceMode LoadDistributionMode @default(STREAM) @map("practice_mode")
  labMode      LoadDistributionMode @default(STREAM) @map("lab_mode")

  /// Кількість підгруп, на які ділиться дисципліна (1 = без поділу).
  /// При ≥2 ВСІ види занять ведуться окремо в кожній підгрупі (своя викладач,
  /// години × кількість підгруп) — напр. іноземна мова, IT, фізкультура.
  subgroupCount Int @default(1) @map("subgroup_count")

  /// Відповідальний викладач за цей компонент у даному семестрі.
  /// null = викладач ще не призначений.
  teacherId String?  @map("teacher_id")
  teacher   Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)

  @@unique([workingCurriculumId, componentTermId])
  @@index([workingCurriculumId])
  @@index([teacherId])
  @@map("working_curriculum_component_terms")
}

// ─── Operational: Group Working Curriculum Assignment ─────────────────────────

/// Прив'язування групи до робочого навчального плану на навчальний рік.
/// Унікальність: одна група — один робочий план на рік.
model GroupWorkingCurriculumAssignment {
  id                  String            @id @default(uuid())
  groupId             String            @map("group_id")
  group               Group             @relation(fields: [groupId], references: [id])
  workingCurriculumId String            @map("working_curriculum_id")
  workingCurriculum   WorkingCurriculum @relation(fields: [workingCurriculumId], references: [id])
  assignmentId        String            @map("assignment_id")
  assignment          GroupCurriculumAssignment @relation(fields: [assignmentId], references: [id])

  academicYear String  @map("academic_year")
  /// Reserved: always true. No deactivation workflow exists yet.
  isActive     Boolean @default(true) @map("is_active")
  assignedBy   String? @map("assigned_by")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([groupId, academicYear])
  @@index([workingCurriculumId])
  @@map("group_working_curriculum_assignments")
}

// ─── Electives ────────────────────────────────────────────────────────────────

/// Підсумок вибору ВК на рівні групи (§3.6, §3.9 Положення).
/// З моменту створення цього запису ВК стає обов'язковим для групи
/// і підлягає внесенню до робочого навчального плану (§3.10).
model GroupElectiveSelection {
  id           String                    @id @default(uuid())
  blockId      String                    @map("block_id")
  block        ElectiveBlock             @relation(fields: [blockId], references: [id])
  componentId  String                    @map("component_id")
  component    CurriculumComponent       @relation(fields: [componentId], references: [id])
  assignmentId String                    @map("assignment_id")
  assignment   GroupCurriculumAssignment @relation(fields: [assignmentId], references: [id])

  /// Сезон (блок × рік), у межах якого зафіксовано підсумок.
  /// null = запис створений до впровадження сезонної фіксації (legacy).
  seasonId String?              @map("season_id")
  season   ElectiveBlockSeason? @relation(fields: [seasonId], references: [id], onDelete: Restrict)

  /// §3.4 — реквізити наказу, якщо підсумок зафіксовано наказом
  /// (кворум 75% не досягнуто або студенти не подали заяв). null = кворум заявами.
  orderNumber String?   @map("order_number")
  orderDate   DateTime? @map("order_date")

  selectedAt DateTime @default(now()) @map("selected_at")
  selectedBy String?  @map("selected_by") // userId

  @@unique([blockId, assignmentId])
  @@index([assignmentId])
  @@index([seasonId])
  @@map("group_elective_selections")
}

/// Канонічний запис вибору ВК студентом.
/// ЄДИНЕ джерело істини для student selection — не дублюється в ElectiveRegistration.
///
/// seasonId → ElectiveBlockSeason → ElectiveBlock (слот плану) + academicYear.
/// academicYear — denormalized від season.academicYear для ефективної фільтрації без JOIN.
/// componentId → CurriculumComponent: обраний варіант (назва, год., кредити з CurriculumComponentTerm).
model StudentElectiveSelection {
  id          String              @id @default(uuid())
  studentId   String              @map("student_id")
  student     Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)

  /// Canonical reference: season.blockId = слот, season.academicYear = рік
  seasonId    String              @map("season_id")
  season      ElectiveBlockSeason @relation(fields: [seasonId], references: [id], onDelete: Restrict)

  /// Обраний варіант дисципліни (один з season.offerings[].component)
  componentId String              @map("component_id")
  component   CurriculumComponent @relation(fields: [componentId], references: [id], onDelete: Restrict)

  /// Denormalized від season.academicYear — тільки для ефективних запитів
  academicYear String             @map("academic_year")

  method         SelectionMethod  @default(VOLUNTARY)
  status         SelectionStatus  @default(PENDING)
  overrideReason String?          @map("override_reason")

  // Audit trail
  submittedAt   DateTime  @default(now()) @map("submitted_at")
  confirmedAt   DateTime? @map("confirmed_at")
  confirmedById String? @map("confirmed_by_id")
  confirmedBy   User?   @relation("ElectiveSelectionConfirmedBy", fields: [confirmedById], references: [id], onDelete: SetNull)

  @@unique([studentId, seasonId])
  @@index([seasonId])
  @@index([studentId])
  @@map("student_elective_selections")
}

// ─── Student Individual Plan ──────────────────────────────────────────────────

/// Індивідуальний навчальний план студента (похідний від групового)
model StudentIndividualPlan {
  id           String                    @id @default(uuid())
  studentId    String                    @unique @map("student_id")
  student      Student                   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  assignmentId String                    @map("assignment_id")
  assignment   GroupCurriculumAssignment @relation(fields: [assignmentId], references: [id])

  isActive   Boolean   @default(true) @map("is_active")
  notes      String?
  approvedAt DateTime? @map("approved_at")
  approvedBy String?   @map("approved_by")

  items StudentIndividualPlanItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@map("student_individual_plans")
}

/// Запис відхилення в індивідуальному навчальному плані студента
model StudentIndividualPlanItem {
  id             String                @id @default(uuid())
  planId         String                @map("plan_id")
  plan           StudentIndividualPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  componentId    String                @map("component_id")
  component      CurriculumComponent   @relation(fields: [componentId], references: [id], onDelete: Restrict)
  semesterNumber Int                   @map("semester_number")

  deviationType IndividualPlanDeviationType @map("deviation_type")
  notes         String?
  resolvedAt    DateTime? @map("resolved_at")

  @@index([planId])
  @@map("student_individual_plan_items")
}

// ─── Elective Components: Catalog + Student Registration ─────────────────────

/// Статус каталогу ВК на поточний навчальний рік.
/// Положення КПЕФК від 01.09.2023, наказ №30-од.
enum CatalogStatus {
  DRAFT  /// Підготовка (до 1 березня): каталог не публікується студентам
  OPEN   /// Вибір відкрито (1 квітня – 15 травня)
  LATE   /// Продовжений вибір за поважних причин (15 травня – 1 червня)
  CLOSED /// Вибір завершено (після 1 червня)
}

/// Спосіб, яким студент отримав ВК (§3.4, §3.5, Додаток 3 Положення).
enum SelectionMethod {
  VOLUNTARY /// Студент обрав самостійно — "Заява"
  ASSIGNED  /// Призначено адміністратором — "Наказ"
}

/// Стан реєстрації студента на ВК.
enum SelectionStatus {
  PENDING   /// Очікує підтвердження (під час OPEN/LATE)
  CONFIRMED /// Підтверджено після 1 червня (§3.9)
  CANCELLED /// Скасовано студентом під час OPEN
}

// ─── Elective Season (річна кампанія вибору) ─────────────────────────────────

/// Річна кампанія вибору ВК (§2.4, §3.1–3.9 Положення КПЕФК).
/// Один запис = один цільовий навчальний рік (рік, НА який обираються ВК).
/// Каталог затверджується педрадою і вводиться наказом директора щороку —
/// метадані цих документів зберігаються тут.
/// Статус кампанії є джерелом істини для bulk-переходів статусів
/// усіх прив'язаних ElectiveBlockSeason.
model ElectiveSeason {
  id           String        @id @default(uuid())
  /// Цільовий навчальний рік, на який здійснюється вибір ("2026-2027")
  academicYear String        @unique @map("academic_year")
  status       CatalogStatus @default(DRAFT)

  /// §3.2 — дата публікації каталогу на сайті (до 01 квітня)
  publishedAt       DateTime? @map("published_at")
  /// §3.4 — дедлайн подачі заяв (15 травня)
  selectionDeadline DateTime? @map("selection_deadline")
  /// §3.8 — дедлайн пізнього вибору з поважних причин (01 червня)
  lateDeadline      DateTime? @map("late_deadline")

  /// §2.4 — затвердження каталогу педагогічною радою
  pedagogicalCouncilDate           DateTime? @map("pedagogical_council_date")
  pedagogicalCouncilProtocolNumber String?   @map("pedagogical_council_protocol_number")
  /// §2.4 — наказ директора про введення каталогу в дію
  directorOrderNumber String?   @map("director_order_number")
  directorOrderDate   DateTime? @map("director_order_date")

  notes String?

  blockSeasons ElectiveBlockSeason[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@map("elective_seasons")
}

// ─── Elective Block Season + Offering (нова архітектура) ─────────────────────

/// Публікація ElectiveBlock (слоту плану) на конкретний навчальний рік.
/// Один запис = один слот × один рік. catalogStatus відкриває/закриває вибір.
/// Параметри (кредити, години, форма контролю) беруться з CurriculumComponentTerm
/// відповідних компонентів, що входять до block.options.
model ElectiveBlockSeason {
  id            String        @id @default(uuid())
  blockId       String        @map("block_id")
  block         ElectiveBlock @relation(fields: [blockId], references: [id], onDelete: Restrict)
  academicYear  String        @map("academic_year")  // "2025-2026"
  catalogStatus CatalogStatus @default(DRAFT)        @map("catalog_status")

  /// Річна кампанія, в межах якої створено цей block-сезон.
  /// null = створений вручну до впровадження кампаній (legacy).
  electiveSeasonId String?         @map("elective_season_id")
  electiveSeason   ElectiveSeason? @relation(fields: [electiveSeasonId], references: [id], onDelete: SetNull)

  offerings       ElectiveOffering[]
  selections      StudentElectiveSelection[]
  groupSelections GroupElectiveSelection[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([blockId, academicYear])
  @@index([academicYear])
  @@map("elective_block_seasons")
}

/// Конкретна дисципліна, доступна студентам у межах сезону (ElectiveBlockSeason).
/// SOURCE OF TRUTH для назви — component.name.
/// SOURCE OF TRUTH для кредитів/годин/форми контролю — component.terms[semester].
/// Тут лише каталогові метадані: силабус, примітка, позначка вищої освіти.
model ElectiveOffering {
  id          String              @id @default(uuid())
  seasonId    String              @map("season_id")
  season      ElectiveBlockSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  componentId String              @map("component_id")
  component   CurriculumComponent @relation(fields: [componentId], references: [id], onDelete: Restrict)

  syllabusUrl String?  @map("syllabus_url")
  isHigherEd  Boolean  @default(false) @map("is_higher_ed")
  description String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([seasonId, componentId])
  @@index([seasonId])
  @@map("elective_offerings")
}

// ─── DEPRECATED: замінено ElectiveBlockSeason + ElectiveOffering ─────────────
// ElectiveComponent і ElectiveRegistration залишені тимчасово для backward compat.
// Будуть видалені після повного переходу backend і frontend на нову архітектуру.

