// ─── Teacher Load: Subject + Lesson Assignments ───────────────────────────────

/// Вид заняття для призначення педагогічного навантаження.
///
/// Законодавча основа: Наказ МОН №686 від 18.06.2021, зі змінами Наказу №472 від 24.05.2022.
///
/// Нормовані Наказом №686 (входять у 720 год/ставку):
///   LECTURE      → п.4  «Лекція»
///   PRACTICE     → п.5  «Практичне заняття»
///   LAB          → п.6  «Лабораторна робота»
///   SEMINAR      → п.7  «Семінар»
///   CONSULTATION → п.9  «Консультації протягом семестру» (2% обсягу — денна; 6% — заочна/дист.)
///
/// Внутрішній показник закладу (не нормований Наказом №686 як окремий вид):
///   SPRS — «Самостійна робота студентів під керівництвом викладача».
///   У Наказі №686 самостійна робота студентів (СРС) є часом студента і в навантаження
///   викладача не входить. SPRS тут позначає години, які заклад самостійно відносить
///   до навчальної роботи викладача (наприклад, перевірка СРС, індивідуальні консультації
///   понад 2%, п.8 «Індивідуальне заняття»). Облік визначається внутрішнім положенням закладу.
enum LessonType {
  LECTURE      // Лекції              — Наказ МОН №686, п.4
  PRACTICE     // Практичні заняття   — Наказ МОН №686, п.5
  LAB          // Лабораторні роботи  — Наказ МОН №686, п.6
  SEMINAR      // Семінари            — Наказ МОН №686, п.7
  CONSULTATION // Консультації        — Наказ МОН №686, п.9 (2%/6% від обсягу дисципліни)
  SPRS         // СПРС (внутрішній показник закладу; не окремий вид у Наказі №686)
}

/// Стан запису навантаження
enum LoadStatus {
  DRAFT     // Чернетка (редагується заступником директора)
  CONFIRMED // Підтверджено наказом директора
}

/// Режим розподілу практичних / лабораторних занять.
/// STREAM    — потоковий формат: один викладач на всі групи потоку (×1 годин).
/// PER_GROUP — окремо на кожну активну групу (×groupCount годин, різні викладачі).
/// Лекції/семінари/консультації/СПРС — завжди потокові (Наказ МОН №686).
enum LoadDistributionMode {
  STREAM
  PER_GROUP
}

/// Призначення навантаження на рівні освітнього компонента (ОК).
///
/// Один запис на (workingCurriculum × componentTerm × group).
/// group = null → потоковий формат (лекції для всього потоку без конкретної групи).
///
/// primaryTeacherId = основний викладач ОК.
/// Він веде всі види занять, для яких у TeacherLoadLessonAssignment немає override.
/// effectiveTeacherId для кожного заняття = overrideTeacherId ?? primaryTeacherId.
model TeacherLoadSubjectAssignment {
  id String @id @default(uuid())

  workingCurriculumId String            @map("working_curriculum_id")
  workingCurriculum   WorkingCurriculum  @relation(fields: [workingCurriculumId], references: [id], onDelete: Cascade)

  curriculumComponentTermId String                  @map("curriculum_component_term_id")
  curriculumComponentTerm   CurriculumComponentTerm @relation(fields: [curriculumComponentTermId], references: [id], onDelete: Restrict)

  /// null = потоковий (лекції); string = конкретна група
  groupId String? @map("group_id")
  group   Group?  @relation(fields: [groupId], references: [id], onDelete: SetNull)

  academicYear String @map("academic_year")

  /// Основний викладач компонента. Якщо overrideTeacherId у lesson = null,
  /// то effectiveTeacher = primaryTeacher.
  primaryTeacherId String?  @map("primary_teacher_id")
  primaryTeacher   Teacher? @relation("SubjectPrimaryTeacher", fields: [primaryTeacherId], references: [id], onDelete: SetNull)

  /// UserId заступника директора, який здійснив генерацію / останнє оновлення
  assignedById String @map("assigned_by_id")
  assignedBy   User   @relation("SubjectAssignedBy", fields: [assignedById], references: [id], onDelete: Restrict)

  /// UserId директора, який підписав наказ (null = ще не підтверджено)
  signedByDirectorId String? @map("signed_by_director_id")
  signedByDirector   User?   @relation("SubjectSignedByDirector", fields: [signedByDirectorId], references: [id], onDelete: SetNull)

  status      LoadStatus @default(DRAFT)
  orderNumber String?    @map("order_number")
  orderDate   DateTime?  @map("order_date")

  lessonAssignments TeacherLoadLessonAssignment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([workingCurriculumId])
  @@index([primaryTeacherId])
  @@index([groupId])
  @@index([status])
  @@index([signedByDirectorId])
  @@map("teacher_load_subject_assignments")
}

/// Деталізація навантаження по виду заняття в рамках TeacherLoadSubjectAssignment.
///
/// overrideTeacherId заповнюється лише тоді, коли конкретний вид заняття
/// веде інший викладач, ніж primaryTeacher батьківського subject assignment.
///
/// effectiveTeacher обчислюється на backend (не зберігається в БД):
///   effectiveTeacherId = overrideTeacherId ?? parent.primaryTeacherId
model TeacherLoadLessonAssignment {
  id String @id @default(uuid())

  subjectAssignmentId String                       @map("subject_assignment_id")
  subjectAssignment   TeacherLoadSubjectAssignment @relation(fields: [subjectAssignmentId], references: [id], onDelete: Cascade)

  lessonType     LessonType @map("lesson_type")
  /// null = вся група; 1/2/3 = конкретна підгрупа (якщо subgroupCount > 1)
  subgroupNumber Int?       @map("subgroup_number")
  /// Годин для цього виду заняття (raw, без множення на кількість груп)
  hours          Int

  /// Викладач-виняток для цього виду заняття.
  /// null → використовується primaryTeacher батьківського subject assignment.
  overrideTeacherId String?  @map("override_teacher_id")
  overrideTeacher   Teacher? @relation("LessonOverrideTeacher", fields: [overrideTeacherId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([subjectAssignmentId])
  @@index([overrideTeacherId])
  @@map("teacher_load_lesson_assignments")
}

// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║                        GROUP LEADER DOMAIN                                  ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

/// Контактна інформація батьків / опікунів студента.
/// Заповнюється керівником групи або адміністрацією.
model ParentInfo {
  id        String  @id @default(cuid())
  studentId String  @unique @map("student_id")
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  motherFullName  String? @map("mother_full_name")
  motherPhone     String? @map("mother_phone")
  motherWorkplace String? @map("mother_workplace")

  fatherFullName  String? @map("father_full_name")
  fatherPhone     String? @map("father_phone")
  fatherWorkplace String? @map("father_workplace")

  guardianFullName  String? @map("guardian_full_name")
  guardianPhone     String? @map("guardian_phone")
  guardianWorkplace String? @map("guardian_workplace")
  /// "бабуся", "дядько" тощо
  guardianRelation  String? @map("guardian_relation")

  address String?
  /// Приватні нотатки керівника групи (не видно студенту)
  notes   String?

  updatedById String? @map("updated_by_id")
  updatedBy   User?   @relation(fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@map("parent_info")
}

/// Журнал адміністративних змін — write-операції з персональними даними.
model AuditLog {
  id         String @id @default(cuid())
  userId     String @map("user_id")
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Тип дії: 'UPDATE_PARENT_INFO', тощо
  action     String
  /// Id цільової сутності (studentId, тощо)
  targetId   String @map("target_id")
  /// Тип цільової сутності: 'Student', тощо
  targetType String @map("target_type")
  ipAddress  String? @map("ip_address")
  metadata   Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([targetId])
  @@map("audit_logs")
}

// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║                          SCHEDULE DOMAIN                                    ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

/// Тип тижня для заняття в розкладі.
/// EVERY  — заняття щотижня (займає і непарний, і парний тиждень).
/// ODD    — лише непарний тиждень (чисельник).
/// EVEN   — лише парний тиждень (знаменник).
enum WeekParity {
  ODD   // Непарний
  EVEN  // Парний
  EVERY // Щотижня
}

/// Стан розкладу групи.
enum ScheduleStatus {
  DRAFT     // Чернетка (диспетчер редагує)
  PUBLISHED // Опубліковано (видно студентам / викладачам)
}

/// Тижневий розклад занять конкретної групи на семестр навчального року.
/// Один на (група × навчальний рік × семестр). Джерело генерації — РНП
/// (WorkingCurriculum), резолвиться через GroupWorkingCurriculumAssignment.
model Schedule {
  id                  String            @id @default(uuid())
  groupId             String            @map("group_id")
  group               Group             @relation(fields: [groupId], references: [id])
  workingCurriculumId String            @map("working_curriculum_id")
  workingCurriculum   WorkingCurriculum @relation(fields: [workingCurriculumId], references: [id], onDelete: Cascade)

  academicYear   String         @map("academic_year")
  semesterNumber Int            @map("semester_number")
  status         ScheduleStatus @default(DRAFT)
  generatedAt    DateTime?      @map("generated_at")
  notes          String?

  /// День тижня виховної години (1=Пн..5=Пт). null = не призначено (ТЗ §3.5).
  /// Час слоту — фіксований (HOMEROOM_BELL), день обирає диспетчер для групи.
  homeroomDayOfWeek Int? @map("homeroom_day_of_week")

  entries ScheduleEntry[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([groupId, academicYear, semesterNumber])
  @@index([workingCurriculumId])
  @@map("schedules")
}

/// Одне заняття у тижневій сітці розкладу.
/// Кілька записів можуть ділити один (day, slot, parity) лише як паралельні підгрупи
/// (різні subgroupNumber, викладачі та аудиторії). Конфлікти обчислюються в сервісі.
model ScheduleEntry {
  id         String   @id @default(uuid())
  scheduleId String   @map("schedule_id")
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  dayOfWeek      Int        @map("day_of_week")  // 1 = Пн ... 5 = Пт
  slotNumber     Int        @map("slot_number")  // 1..5 (номер пари)
  weekParity     WeekParity @default(EVERY) @map("week_parity")
  lessonType     LessonType @map("lesson_type")
  /// null = вся група; 1/2/3 = конкретна підгрупа
  subgroupNumber Int?       @map("subgroup_number")

  curriculumComponentTermId String                  @map("curriculum_component_term_id")
  curriculumComponentTerm   CurriculumComponentTerm @relation(fields: [curriculumComponentTermId], references: [id], onDelete: Restrict)

  teacherId   String?    @map("teacher_id")
  teacher     Teacher?   @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  classroomId String?    @map("classroom_id")
  classroom   Classroom? @relation(fields: [classroomId], references: [id], onDelete: SetNull)

  /// Посилання на онлайн-конференцію для дистанційного/змішаного заняття (ТЗ §3.6, §7.4).
  onlineUrl String? @map("online_url")

  substitutions  ScheduleSubstitution[]
  lessonSessions LessonSession[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([scheduleId])
  @@index([teacherId])
  @@index([classroomId])
  @@map("schedule_entries")
}

/// Тип оперативної заміни заняття на конкретну дату (ТЗ §3.8, §7.3).
enum SubstitutionType {
  CANCELLED      // Заняття скасовано на цю дату
  TEACHER_CHANGE // Заміна викладача
  ROOM_CHANGE    // Заміна аудиторії
  MOVED          // Перенесено на інший день/слот
}

/// Оперативна заміна/перенесення/скасування заняття на конкретну календарну
/// дату — без зміни базового тижневого шаблону (ТЗ §3.8 «облік відпрацювань,
/// заміщень, перенесень», §7.3 «форс-мажорні зміни»).
model ScheduleSubstitution {
  id      String        @id @default(uuid())
  entryId String        @map("entry_id")
  entry   ScheduleEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  /// Конкретна календарна дата, на яку діє заміна.
  date DateTime
  type SubstitutionType

  /// Для MOVED — новий день/слот; інакше null.
  newDayOfWeek  Int? @map("new_day_of_week")
  newSlotNumber Int? @map("new_slot_number")

  /// Для TEACHER_CHANGE / ROOM_CHANGE — заміняючий ресурс.
  replacementTeacherId   String?    @map("replacement_teacher_id")
  replacementTeacher     Teacher?   @relation("SubstitutionTeacher", fields: [replacementTeacherId], references: [id], onDelete: SetNull)
  replacementClassroomId String?    @map("replacement_classroom_id")
  replacementClassroom   Classroom? @relation("SubstitutionClassroom", fields: [replacementClassroomId], references: [id], onDelete: SetNull)

  reason      String?
  createdById String? @map("created_by_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([entryId, date])
  @@index([entryId])
  @@index([date])
  @@map("schedule_substitutions")
}

/// Налаштування модуля розкладу (ТЗ §3.4, §4 — Адміністратор системи).
/// Один рядок на заклад (singleton). Ліміти пар/день — параметри, а не хардкод.
model ScheduleSettings {
  id String @id @default(uuid())

  /// Макс. пар на день для денної форми (ТЗ §3.4).
  maxPairsFullTime Int  @default(4) @map("max_pairs_full_time")
  /// Макс. пар на день для заочної/дистанційної/змішаної; null = без обмеження.
  maxPairsPartTime Int? @map("max_pairs_part_time")
  /// Чи рахується виховна година в ліміті пар на день (ТЗ §3.5).
  homeroomCountsToLimit Boolean @default(false) @map("homeroom_counts_to_limit")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("schedule_settings")
}

// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║                 SUBGROUPS + ATTENDANCE (електронний журнал)                  ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

/// Членство студента в підгрупі конкретної дисципліни-семестру (поділ за списком/
/// рівнем). Потрібне для журналу підгрупових занять (практичні/лабораторні/мови).
model StudentSubgroup {
  id String @id @default(uuid())

  curriculumComponentTermId String                  @map("curriculum_component_term_id")
  curriculumComponentTerm   CurriculumComponentTerm @relation(fields: [curriculumComponentTermId], references: [id], onDelete: Cascade)

  studentId String  @map("student_id")
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  /// Денормалізовано для запитів поділу по групі.
  groupId String @map("group_id")
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  subgroupNumber Int @map("subgroup_number") // 1..N

  assignedById String? @map("assigned_by_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([curriculumComponentTermId, studentId])
  @@index([curriculumComponentTermId, subgroupNumber])
  @@index([groupId, curriculumComponentTermId])
  @@index([studentId])
  @@map("student_subgroups")
}

/// Статус присутності студента на занятті (за замовчуванням — відсутній).
enum AttendanceStatus {
  ABSENT  // Відсутній
  PRESENT // Присутній
  LATE    // Запізнився
}

/// Одна фактична подія заняття = сторінка журналу на конкретну дату.
/// Знімкує ідентичність заняття, щоб переживати перегенерацію розкладу
/// (scheduleEntryId — мʼякий звʼязок, onDelete: SetNull).
model LessonSession {
  id String @id @default(uuid())

  date           DateTime @db.Date
  academicYear   String   @map("academic_year")
  semesterNumber Int      @map("semester_number")

  // ── Знімок ідентичності заняття ──
  groupId String @map("group_id")
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Restrict)

  curriculumComponentTermId String                  @map("curriculum_component_term_id")
  curriculumComponentTerm   CurriculumComponentTerm @relation(fields: [curriculumComponentTermId], references: [id], onDelete: Restrict)
  subjectName               String                  @map("subject_name") @db.VarChar(300)

  teacherId String  @map("teacher_id")
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Restrict)

  slotNumber     Int        @map("slot_number")
  weekParity     WeekParity @map("week_parity")
  lessonType     LessonType @map("lesson_type") // фактичний вид, обирає викладач
  subgroupNumber Int        @default(0) @map("subgroup_number") // 0 = вся група

  topic String? @db.VarChar(500)

  /// Мʼякий звʼязок із заняттям розкладу (перегенерація не знищує журнал).
  scheduleEntryId String?        @map("schedule_entry_id")
  scheduleEntry   ScheduleEntry? @relation(fields: [scheduleEntryId], references: [id], onDelete: SetNull)

  recordedById String? @map("recorded_by_id")
  recordedBy   User?   @relation("LessonSessionRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)

  records AttendanceRecord[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime? @map("deleted_at") // soft delete (аудит)

  @@unique([groupId, date, slotNumber, subgroupNumber])
  @@index([teacherId, date])
  @@index([groupId, academicYear, semesterNumber])
  @@index([curriculumComponentTermId])
  @@index([date])
  @@map("lesson_sessions")
}

/// Запис відвідуваності/оцінки студента на занятті.
model AttendanceRecord {
  id String @id @default(uuid())

  lessonSessionId String        @map("lesson_session_id")
  lessonSession   LessonSession @relation(fields: [lessonSessionId], references: [id], onDelete: Cascade)

  studentId   String  @map("student_id")
  student     Student @relation(fields: [studentId], references: [id], onDelete: Restrict)
  /// Знімок ПІБ — аудит і стабільність, якщо студент змінить групу.
  studentName String  @map("student_name") @db.VarChar(300)

  status  AttendanceStatus @default(ABSENT)
  /// Поточна оцінка 1..12 (національна 12-бальна; 5-бальні значення вкладаються).
  grade   Int?
  comment String?          @db.VarChar(1000)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([lessonSessionId, studentId])
  @@index([studentId])
  @@index([lessonSessionId])
  @@map("attendance_records")
}

// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║                        INSTITUTION (ЄДЕБО university/get)                    ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

/// Інформація про заклад освіти (ВСП КПЕФК) з ЄДЕБО — POST /api/university/get.
/// Один запис = наш заклад (universityId = EDEBO_CODE). Оновлюється щотижневою
/// синхронізацією. Корисні поля винесено в колонки, повна відповідь — у `raw`.
model University {
  id           String  @id @default(uuid())
  universityId Int     @unique @map("university_id") // Код закладу (числовий)
  code         String?                               // GUID закладу

  name        String?
  shortName   String? @map("short_name")
  nameEn      String? @map("name_en")
  shortNameEn String? @map("short_name_en")
  edrpou      String?                                 // Ідент. код в ЄДРПОУ

  registrationDate   DateTime? @map("registration_date")
  universityTypeName String?   @map("university_type_name")
  educationType      String?   @map("education_type")
  juristicalType     String?   @map("juristical_type")  // Відокремлений структурний підрозділ
  finansingType      String?   @map("finansing_type")   // Форма власності
  governanceType     String?   @map("governance_type")  // Орган управління
  orgPravForm        String?   @map("org_prav_form")     // Організаційно-правова форма
  riskRank           String?   @map("risk_rank")         // Ступінь ризику

  isClosed            Boolean   @default(false) @map("is_closed")
  closeStatusTypeName String?   @map("close_status_type_name")
  closeReason         String?   @map("close_reason")
  closeDate           DateTime? @map("close_date")
  isMilitaryChair     Boolean   @default(false) @map("is_military_chair")

  // Місце провадження освітньої діяльності (основне)
  postIndex       String? @map("post_index")
  katottgFullName String? @map("katottg_full_name")
  addressStreet   String? @map("address_street") // streetTypeName + addressFull
  houseNumber     String? @map("house_number")

  // Місцезнаходження (юридична адреса)
  postIndexLegal     String? @map("post_index_legal")
  katottgFullNameU   String? @map("katottg_full_name_u")
  addressStreetLegal String? @map("address_street_legal")
  houseNumberLegal   String? @map("house_number_legal")

  // Контакти
  phoneNumber String? @map("phone_number")
  email       String?
  webSite     String? @map("web_site")

  // Керівник
  rectorFullName        String? @map("rector_full_name")
  rectorLastName        String? @map("rector_last_name")
  rectorFirstName       String? @map("rector_first_name")
  rectorMiddleName      String? @map("rector_middle_name")
  rectorFullNameGenCase String? @map("rector_full_name_gen_case")
  rectorPosition        String? @map("rector_position")
  rectorPhone           String? @map("rector_phone")
  rectorEmail           String? @map("rector_email")
  rectorWorkDateStart   DateTime? @map("rector_work_date_start")
  rectorWorkDateFinish   DateTime? @map("rector_work_date_finish")

  /// Повна відповідь ЄДЕБО (для полів, не винесених в окремі колонки)
  raw Json?

  syncedAt  DateTime @map("synced_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@map("universities")
}

// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║                          DIPLOMA DOMAIN                                      ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

/// Варіант підсумкової атестації (визначає шаблон і фінальний ОК).
enum DiplomaVariant {
  EXAM            // Кваліфікаційний іспит
  EDKI            // ЄДКІ (єдиний державний кваліфікаційний іспит)
  DIPLOMA_WORK    // Дипломна робота
  DIPLOMA_PROJECT // Дипломний проєкт
}

/// Тип рядка зведеної відомості (для рендеру таблиці §4.3 додатка).
enum DiplomaComponentType {
  REGULAR     // Обов'язковий ОК
  ELECTIVE    // Вибірковий компонент (ВК)
  COURSE_WORK // Курсова робота (без коду/кредитів, лише оцінка)
  PRACTICE    // Практика
  ATTESTATION // Кваліфікаційна робота / проєкт / іспит / ЄДКІ
}

/// Підсумкова оцінка за шкалою закладу (двомовні підписи рахуються в сервісі).
enum DiplomaGrade {
  EXCELLENT    // Відмінно / Excellent
  GOOD         // Добре / Good
  SATISFACTORY // Задовільно / Satisfactory
  PASSED       // Зараховано / Passed
}

/// Стан диплома в нашій системі.
enum DiplomaStatus {
  DRAFT // Чернетка (заповнюється зведена відомість)
  READY // Готовий до видачі
}

/// Шаблон диплома + додатка на спеціальність × варіант атестації.
/// Зберігає .docx-шаблони (docxtemplater) і впорядковану структуру ОК.
model DiplomaTemplate {
  id            String         @id @default(uuid())
  name          String
  specialtyCode String?        @map("specialty_code") // "122", "073" — для авто-підбору з XML
  specialtyName String?        @map("specialty_name")
  variant       DiplomaVariant

  /// .docx-шаблони з плейсхолдерами (docxtemplater). null = ще не завантажено.
  diplomaDocx  Bytes? @map("diploma_docx")
  addendumDocx Bytes? @map("addendum_docx")

  /// Назва кваліфікації та ступеня для шаблону (2 рядки, роздільно укр. / англ.).
  qualificationNameUk  String? @map("qualification_name_uk")   // рядок 1, напр. "Фаховий молодший бакалавр "
  qualificationNameUk2 String? @map("qualification_name_uk2")  // рядок 2, напр. "з комп'ютерних наук"
  qualificationNameEn  String? @map("qualification_name_en")   // рядок 1 англ.
  qualificationNameEn2 String? @map("qualification_name_en2")  // рядок 2 англ.
  degreeNameUk         String? @map("degree_name_uk")          // напр. "Фаховий молодший бакалавр"
  degreeNameEn         String? @map("degree_name_en")          // напр. "Professional Junior Bachelor"

  /// Рядок тривалості навчання для §7.1, напр. "01/09/2022-30/06/2026".
  studyPeriod String? @map("study_period")

  /// Акредитація (заповнюється вручну або підвантажується з ЄДЕБО).
  accrCertNumber      String? @map("accr_cert_number")     // Номер сертифіката (напр. НД-IV №150)
  accrCertSeries      String? @map("accr_cert_series")     // Серія сертифіката
  accrCertDate        String? @map("accr_cert_date")       // Дата видачі сертифіката (напр. "09/06/2019")
  accrCertEndDate     String? @map("accr_cert_end_date")   // Строк дії (рядок, напр. "2027-06-30")
  accrProtocolNumber  String? @map("accr_protocol_number") // Номер протоколу акредитації
  accrInstitutionName   String? @map("accr_institution_name")    // Орган акредитації укр.
  accrInstitutionNameEn String? @map("accr_institution_name_en") // Орган акредитації англ.

  notes    String?
  isActive Boolean @default(true) @map("is_active")

  components DiplomaTemplateComponent[]
  diplomas   Diploma[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([specialtyCode])
  @@map("diploma_templates")
}

/// Рядок структури зведеної відомості в шаблоні (без оцінок).
model DiplomaTemplateComponent {
  id         String          @id @default(uuid())
  templateId String          @map("template_id")
  template   DiplomaTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  code        String?              // "ОК 1", "ВК 1", null для курсових
  nameUk      String               @map("name_uk")
  nameEn      String?              @map("name_en")
  ects        Decimal?             @db.Decimal(5, 1) // null для курсових
  type        DiplomaComponentType
  /// Форма контролю → визначає шкалу оцінювання у зведеній відомості.
  /// CREDIT = зараховано/не зараховано; EXAM/GRADED_CREDIT/null = диференційована (Відм/Добре/Задов).
  controlForm TermControlForm?     @map("control_form")
  orderIndex  Int                  @map("order_index")

  @@index([templateId, orderIndex])
  @@map("diploma_template_components")
}

/// Партія замовлення дипломів — один імпорт XML ЄДЕБО (ODM).
model DiplomaBatch {
  id             String  @id @default(uuid())
  name           String
  academicYear   String? @map("academic_year")
  sourceFileName String? @map("source_file_name")
  importedById   String? @map("imported_by_id")
  count          Int     @default(0)

  diplomas Diploma[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("diploma_batches")
}

/// Диплом конкретного студента (знімок з XML ЄДЕБО + зведена відомість).
model Diploma {
  id      String        @id @default(uuid())
  batchId String?       @map("batch_id")
  batch   DiplomaBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  templateId String?          @map("template_id")
  template   DiplomaTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  // ── Особа (знімок з XML) ──
  lastNameUk     String  @map("last_name_uk")
  firstNameUk    String  @map("first_name_uk")
  lastNameEn     String? @map("last_name_en")
  firstNameEn    String? @map("first_name_en")
  birthday       DateTime?
  edeboPersonCode   String? @map("edebo_person_code")     // PersonCode (GUID)
  personId          Int?    @map("person_id")             // код картки фіз. особи в ЄДЕБО (§1.4 додатка)
  personEducationId Int?    @map("person_education_id")    // код картки навчання в ЄДЕБО
  inn            String?
  sexName        String? @map("sex_name")

  // ── Документ ──
  documentSeries String?   @map("document_series") // X26
  documentNumber String?   @map("document_number")
  supplementId   Int?      @map("supplement_id")   // реєстр. номер додатка
  graduateDate   DateTime? @map("graduate_date")
  issueDate      DateTime? @map("issue_date")

  // ── Академічне (знімок) ──
  specialityName    String? @map("speciality_name")
  specialityNameEn  String? @map("speciality_name_en")
  qualificationName String? @map("qualification_name")
  studyProgramName  String? @map("study_program_name")
  studyProgramNameEn String? @map("study_program_name_en")
  studyGroupName    String? @map("study_group_name")
  courseName        String? @map("course_name")
  accreditationName   String? @map("accreditation_name")
  accreditationNameEn String? @map("accreditation_name_en")

  // ── Підпис / заклад (знімок) ──
  bossFio              String? @map("boss_fio")     // Ірина ВАХОВИЧ
  bossPost             String? @map("boss_post")    // Ректор
  bossFioEn            String? @map("boss_fio_en")
  bossPostEn           String? @map("boss_post_en")
  universityPrintName   String? @map("university_print_name")
  universityPrintNameEn String? @map("university_print_name_en")

  paymentTypeName   String? @map("payment_type_name")
  educationFormName String? @map("education_form_name")

  // ── Документ про освіту — підстава для вступу (§6.2.2, з ЄДЕБО physPersons/documents) ──
  entryDocumentUk          String?  @map("entry_document_uk")            // Опис документа укр.
  entryDocumentEn          String?  @map("entry_document_en")            // Опис документа англ.
  entryYearEnd             Int?     @map("entry_year_end")               // Рік закінчення поперед. освіти (резерв)

  // ── Період навчання §7.1 (зі Student.educationDateBegin/End, матч за personCodeU) ──
  studyDateBegin           DateTime? @map("study_date_begin")
  studyDateEnd             DateTime? @map("study_date_end")

  // ── Ручний ввід ──
  qualificationWorkTitleUk String?  @map("qualification_work_title_uk")
  qualificationWorkTitleEn String?  @map("qualification_work_title_en")
  /// true = з відзнакою. Авто за §4.5 з можливістю override.
  isHonors  Boolean       @default(false) @map("is_honors")
  status    DiplomaStatus @default(DRAFT)

  components DiplomaComponent[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([batchId])
  @@index([templateId])
  @@map("diplomas")
}

/// Рядок зведеної відомості диплома (знімок ОК + оцінка).
model DiplomaComponent {
  id        String  @id @default(uuid())
  diplomaId String  @map("diploma_id")
  diploma   Diploma @relation(fields: [diplomaId], references: [id], onDelete: Cascade)

  code        String?
  nameUk      String               @map("name_uk")
  nameEn      String?              @map("name_en")
  ects        Decimal?             @db.Decimal(5, 1)
  type        DiplomaComponentType
  controlForm TermControlForm?     @map("control_form") // шкала оцінювання (див. DiplomaTemplateComponent)
  orderIndex  Int                  @map("order_index")
  grade       DiplomaGrade?

  @@index([diplomaId, orderIndex])
  @@map("diploma_components")
}
