  isHigherEd    Boolean       @default(false) @map("is_higher_ed")
  catalogStatus CatalogStatus @default(DRAFT) @map("catalog_status")

  /// Прив'язка до терму навчального плану для авто-заповнення кредитів/годин/форми контролю.
  /// null = адмін вводить ectsCredits вручну (перехідний період).
  curriculumTermId String?                  @unique @map("curriculum_term_id")
